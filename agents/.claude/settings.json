            "type": "command",
            "command": "bash ~/.claude/myscripts/permission-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/myscripts/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
